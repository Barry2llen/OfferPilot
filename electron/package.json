{
  "name": "offer-pilot-electron",
  "private": true,
  "version": "0.0.0",
  "description": "OfferPilot desktop application.",
  "author": "barry2llen",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run build:win",
    "build:electron": "tsc && vite build",
    "build:frontend": "npm --prefix ../frontend run build && node scripts/prepare-frontend.mjs",
    "build:backend": "uv run --project ../backend pyinstaller ../backend/packaging/offer_pilot_api.spec --noconfirm --clean --distpath resources/backend-build/dist --workpath resources/backend-build/build && node scripts/prepare-backend.mjs",
    "build:win": "npm run build:frontend && npm run build:backend && npm run build:electron && electron-builder --win --x64",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "@typescript-eslint/eslint-plugin": "^7.1.1",
    "@typescript-eslint/parser": "^7.1.1",
    "@vitejs/plugin-react": "^4.2.1",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "typescript": "^5.2.2",
    "vite": "^5.1.6",
    "electron": "^30.0.1",
    "electron-builder": "^24.13.3",
    "vite-plugin-electron": "^0.28.6",
    "vite-plugin-electron-renderer": "^0.14.5"
  },
  "main": "dist-electron/main.js"
}
